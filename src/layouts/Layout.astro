---
import TopBar from '../components/TopBar.astro';
import BottomBar from '../components/BottomBar.astro';
import '../styles/tokens.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Crosswinds Jazz Band – San Francisco Bay Area' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/assets/logo-transparent.png" />
    <title>{title} | Crosswinds Jazz</title>
  </head>
  <body>
    <TopBar />
    <main class="main-content">
      <slot />
    </main>
    <BottomBar />
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    background-color: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-body);
    line-height: 1.6;
  }

  .main-content {
    min-height: calc(100vh - var(--nav-height) - 120px);
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  a {
    color: inherit;
  }
</style>
